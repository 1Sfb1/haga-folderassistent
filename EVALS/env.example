# === LLM Provider ===
# "ollama" voor lokaal (gratis), "openai" voor OpenAI API
LLM_PROVIDER=openai

# === Ollama (lokaal) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# === OpenAI ===
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini

# === Embeddings ===
# "local" voor sentence-transformers (GPU), "openai" voor OpenAI embeddings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=intfloat/multilingual-e5-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# === Vector Store ===
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=haga_folders


# === RAG Settings ===
MIN_CHUNK_LENGTH=100
CHUNK_SIZE=300
CHUNK_OVERLAP=50
TOP_K=10
RELEVANCE_THRESHOLD=0.30 
MAX_HISTORY_TURNS=6

# === HyDE (Hypothetical Document Embeddings) ===
# Zet op "true" om HyDE retrieval te activeren.
# HyDE kost één extra LLM-call per request maar verbetert retrieval
# bij semantische mismatch tussen patiëntenvraag en foldertaal.
# Gebruik eerst: python 2_test_retrieval.py --compare
# om te meten of HyDE jouw corpus verbetert vóór je het aanzet.
HYDE_ENABLED=false
HYDE_MAX_TOKENS=200
HYDE_TEMPERATURE=0.3

# === Server ===
HOST=0.0.0.0
PORT=8000
